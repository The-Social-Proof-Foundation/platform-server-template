# Server
PORT=8080
ENVIRONMENT=development

# Postgres (primary + optional read replica)
POSTGRES_URL=postgres://platform:platform@127.0.0.1:5432/platform
POSTGRES_READ_URL=
POSTGRES_SSL=

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_STORE_DURATION=3600

# Auth
JWT_SECRET=dev-jwt-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TOKEN_DURATION=3600
JWT_REFRESH_TOKEN_DURATION=604800
INTERNAL_API_KEY=dev-internal-key

# MySo chain indexer (enable on exactly one instance)
INDEXER_ENABLED=false
MYSO_GRPC_URL=
MYSO_NETWORK=devnet
PLATFORM_ID=

# Stream webhooks (generic HMAC-verified ingress)
STREAM_WEBHOOK_SECRET=

# Analytics pipeline (optional — use docker compose --profile analytics)
ANALYTICS_ENABLED=false
REDPANDA_BROKERS=localhost:9092
REDPANDA_SSL_ENABLED=false
CLICKHOUSE_INGEST_ENABLED=false
CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_DATABASE=platform_analytics

# Push + email (global fallbacks; per-platform keys live in platform_delivery_config)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_KEY_PATH=
APNS_ENVIRONMENT=sandbox
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional engagement features (disabled by default)
REFERRALS_ENABLED=false
INVITES_ENABLED=false

# Waitlist / early access (disabled by default)
WAITLIST_ENABLED=false
WAITLIST_BATCH_ADMISSION_ENABLED=true
WAITLIST_INVITE_BYPASS_ENABLED=true
INVITE_CIRCULATION_PUBLIC=true
