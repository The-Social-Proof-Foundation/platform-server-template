# Server
PORT=8080
ENVIRONMENT=development

# Postgres (primary + optional read replica)
# Default maps to Docker Compose on host port 5433 when local Postgres uses 5432
POSTGRES_URL=postgres://platform:platform@127.0.0.1:5433/platform
POSTGRES_READ_URL=
POSTGRES_SSL=

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_STORE_DURATION=3600

# Auth
JWT_SECRET=dev-jwt-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TOKEN_DURATION=3600
JWT_REFRESH_TOKEN_DURATION=604800
INTERNAL_API_KEY=dev-internal-key

# MySo side-effect worker (enable on exactly one instance)
INDEXER_ENABLED=false
MYSO_GRPC_URL=
MYSO_NETWORK=devnet
PLATFORM_ID=

# Social event webhooks (hosted MySocial push — alternative to gRPC worker)
SOCIAL_WEBHOOK_SECRET=

# Stream webhooks (generic HMAC-verified ingress)
STREAM_WEBHOOK_SECRET=

# Analytics pipeline (optional — use docker compose --profile analytics)
ANALYTICS_ENABLED=false
REDPANDA_BROKERS=localhost:9092
REDPANDA_SSL_ENABLED=false
CLICKHOUSE_INGEST_ENABLED=false
CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_DATABASE=platform_analytics

# Push + email (global fallbacks; per-platform keys live in platform_delivery_config)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_KEY_PATH=
APNS_ENVIRONMENT=sandbox
FCM_SERVER_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# OpenAI embeddings (text-embedding-3-large, 3072 dims)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDINGS_ENABLED=true

# MySocial GraphQL (blended feed reads)
MYSO_GRAPHQL_URL=

# Public app URL for email verification links
APP_PUBLIC_URL=http://localhost:8080
EMAIL_VERIFICATION_ENABLED=true

# Optional engagement features (disabled by default)
REFERRALS_ENABLED=false
INVITES_ENABLED=false

# Waitlist / early access (disabled by default)
WAITLIST_ENABLED=false
WAITLIST_BATCH_ADMISSION_ENABLED=true
WAITLIST_INVITE_BYPASS_ENABLED=true
INVITE_CIRCULATION_PUBLIC=true

# Prometheus metrics (separate port from API)
METRICS_ENABLED=true
METRICS_PORT=9091
# Use 0.0.0.0 when Prometheus runs in Docker (docker compose --profile monitoring)
METRICS_BIND=127.0.0.1
